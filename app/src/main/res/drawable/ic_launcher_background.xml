<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher icon background — crimson radial gradient.
    Using <shape> instead of <vector>+aapt:attr so all OEM launchers
    (including ColorOS) can render it without inline-attribute parsing.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="200%p"
        android:startColor="#EF5350"
        android:endColor="#7F0000" />
</shape>
